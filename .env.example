# 服务器配置
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=3000

# 日志级别
RUST_LOG=gateway=debug,tower_http=debug

# 交易所配置
APP__EXCHANGES__TIMEOUT_SECS=10
APP__EXCHANGES__BINANCE__ENABLED=true
APP__EXCHANGES__BINANCE__BASE_URL=https://api.binance.com
APP__EXCHANGES__BITGET__ENABLED=true
APP__EXCHANGES__BITGET__BASE_URL=https://api.bitget.com
APP__EXCHANGES__APININJAS__ENABLED=true
APP__EXCHANGES__APININJAS__BASE_URL=https://api.api-ninjas.com
APP__EXCHANGES__APININJAS__API_KEY=YOUR_API_KEY_HERE
APP__EXCHANGES__DEXSCREENER__ENABLED=true
APP__EXCHANGES__DEXSCREENER__BASE_URL=https://api.dexscreener.com